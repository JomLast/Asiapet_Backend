  "small_mammal": {
    "name": "Small Mammal Pain Checklist (GP, hamster, hedgehog, etc.)",
    "intro": "Score 1 per present sign. Bruxism + anorexia + reduced fecal = red flag — emergency.",
    "type": "checklist",
    "items": [
      "Immobility / lethargy / isolation",
      "Half-closed dull eyes",
      "Pushing abdomen on floor",
      "Bruxism (teeth grinding) — SEVERE PAIN sign",
      "Anorexia",
      "Reduced or absent fecal output — RED FLAG",
      "Chewing / over-grooming affected area",
      "Aggression in normally docile animal",
      "Hunched posture / piloerection",
      "Weight loss",
      "Reluctance to move"
    ]
  }
}